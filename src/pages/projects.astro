---
import BaseLayout from '../layouts/BaseLayout.astro';
import projects from '../data/projects.json';

// Curated, hand-updated list (src/data/projects.json) — deliberately NOT an
// automated pull of all GitHub repos (master plan Part 1, §6).
const backend = projects.filter((p) => p.category === 'backend');
const ai = projects.filter((p) => p.category === 'ai');
---

<BaseLayout
  title="Projects"
  description="Real shipped work: L2 rollup infrastructure at Gelato, multi-chain wallet analytics on ClickHouse at Moralis, an RWA swap platform, plus open-source Claude Code plugins (ContextSpin, RecallCheck) and RAG evals."
>
  <h1>Projects</h1>
  <p>
    Curated list of real shipped work. The backend and infrastructure work is
    proprietary, so those entries link to the products, not repos; the AI tooling
    is open source. The fuller story behind several of these lives in
    <a href="/notes">Field Notes</a>.
  </p>

  <h2>Backend &amp; infrastructure</h2>
  {
    backend.map((project) => (
      <article class="project" id={project.id}>
        <h3>{project.name}</h3>
        <p class="tags">{project.tags.join(' · ')}</p>
        <p>{project.description}</p>
        {(project.repo || project.link || project.note) && (
          <p class="links">
            {project.repo && <a href={project.repo}>Repository</a>}
            {project.repo && (project.link || project.note) && ' · '}
            {project.link && <a href={project.link.url}>{project.link.label}</a>}
            {project.link && project.note && ' · '}
            {project.note && <a href={project.note}>Field Note</a>}
          </p>
        )}
      </article>
    ))
  }

  <h2>AI tooling &amp; open source</h2>
  {
    ai.map((project) => (
      <article class="project" id={project.id}>
        <h3>{project.name}</h3>
        <p class="tags">{project.tags.join(' · ')}</p>
        <p>{project.description}</p>
        {(project.repo || project.link || project.note) && (
          <p class="links">
            {project.repo && <a href={project.repo}>Repository</a>}
            {project.repo && (project.link || project.note) && ' · '}
            {project.link && <a href={project.link.url}>{project.link.label}</a>}
            {project.link && project.note && ' · '}
            {project.note && <a href={project.note}>Field Note</a>}
          </p>
        )}
      </article>
    ))
  }
</BaseLayout>
